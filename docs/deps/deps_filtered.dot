digraph "spectre" {
    node [style=filled, fontname="Helvetica"]
    edge [color="#888888"]
node [
  fontsize = "12"
];

    "node0" [ label = "SDL3-static\n(SDL3::SDL3)\n(SDL3::SDL3-static)", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node2" [ label = "SDL3_test\n(SDL3::SDL3_test)", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node3" [ label = "freetype", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node4" [ label = "harfbuzz", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node4" -> "node3"  // harfbuzz -> freetype
    "node5" [ label = "mpack_lib", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node6" [ label = "spectre", shape = egg, fillcolor="#2d6a9f", fontcolor="white" ];
    "node7" [ label = "spectre-font", shape = octagon, fillcolor="#f0a868", fontcolor="black" ];
    "node7" -> "node3"  // spectre-font -> freetype
    "node7" -> "node4"  // spectre-font -> harfbuzz
    "node8" [ label = "spectre-types", shape = octagon, fillcolor="#c9a8e0", fontcolor="black" ];
    "node7" -> "node8"  // spectre-font -> spectre-types
    "node6" -> "node7" [ style = dotted ] // spectre -> spectre-font
    "node9" [ label = "spectre-grid", shape = octagon, fillcolor="#f0a868", fontcolor="black" ];
    "node9" -> "node8"  // spectre-grid -> spectre-types
    "node6" -> "node9" [ style = dotted ] // spectre -> spectre-grid
    "node10" [ label = "spectre-nvim", shape = octagon, fillcolor="#5b8dd9", fontcolor="white" ];
    "node10" -> "node0"  // spectre-nvim -> SDL3-static
    "node10" -> "node5"  // spectre-nvim -> mpack_lib
    "node10" -> "node8"  // spectre-nvim -> spectre-types
    "node6" -> "node10" [ style = dotted ] // spectre -> spectre-nvim
    "node11" [ label = "spectre-renderer", shape = octagon, fillcolor="#7ec8a4", fontcolor="black" ];
    "node11" -> "node0"  // spectre-renderer -> SDL3-static
    "node11" -> "node8"  // spectre-renderer -> spectre-types
    "node12" [ label = "spectre-window", shape = octagon, fillcolor="#7ec8a4", fontcolor="black" ];
    "node12" -> "node0"  // spectre-window -> SDL3-static
    "node12" -> "node8"  // spectre-window -> spectre-types
    "node11" -> "node12"  // spectre-renderer -> spectre-window
    "node13" [ label = "vk-bootstrap\n(vk-bootstrap::vk-bootstrap)", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node11" -> "node13" [ style = dotted ] // spectre-renderer -> vk-bootstrap
    "node6" -> "node11" [ style = dotted ] // spectre -> spectre-renderer
    "node6" -> "node8" [ style = dotted ] // spectre -> spectre-types
    "node14" [ label = "spectre-rpc-fake", shape = egg, fillcolor="#f4e04d", fontcolor="black" ];
    "node14" -> "node10" [ style = dotted ] // spectre-rpc-fake -> spectre-nvim
    "node15" [ label = "spectre-tests", shape = egg, fillcolor="#f4e04d", fontcolor="black" ];
    "node15" -> "node7" [ style = dotted ] // spectre-tests -> spectre-font
    "node15" -> "node9" [ style = dotted ] // spectre-tests -> spectre-grid
    "node15" -> "node10" [ style = dotted ] // spectre-tests -> spectre-nvim
    "node15" -> "node11" [ style = dotted ] // spectre-tests -> spectre-renderer
}
