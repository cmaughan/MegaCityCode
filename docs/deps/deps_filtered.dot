digraph "megacitycode" {
    node [style=filled, fontname="Helvetica"]
    edge [color="#888888"]
node [
  fontsize = "12"
];

    "node0" [ label = "SDL3-static\n(SDL3::SDL3)\n(SDL3::SDL3-static)", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node1" [ label = "SDL_uclibc", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node0" -> "node1"  // SDL3-static -> SDL_uclibc
    "node2" [ label = "SDL3_test\n(SDL3::SDL3_test)", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node3" [ label = "freetype", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node4" [ label = "harfbuzz", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node4" -> "node3"  // harfbuzz -> freetype
    "node5" [ label = "megacitycode", shape = egg, fillcolor="#2d6a9f", fontcolor="white" ];
    "node6" [ label = "megacitycode-font", shape = octagon, fillcolor="#f0a868", fontcolor="black" ];
    "node6" -> "node3"  // megacitycode-font -> freetype
    "node6" -> "node4"  // megacitycode-font -> harfbuzz
    "node7" [ label = "megacitycode-types", shape = octagon, fillcolor="#c9a8e0", fontcolor="black" ];
    "node6" -> "node7"  // megacitycode-font -> megacitycode-types
    "node5" -> "node6" [ style = dotted ] // megacitycode -> megacitycode-font
    "node8" [ label = "megacitycode-grid", shape = octagon, fillcolor="#f0a868", fontcolor="black" ];
    "node8" -> "node7"  // megacitycode-grid -> megacitycode-types
    "node5" -> "node8" [ style = dotted ] // megacitycode -> megacitycode-grid
    "node9" [ label = "megacitycode-renderer", shape = octagon, fillcolor="#7ec8a4", fontcolor="black" ];
    "node9" -> "node0"  // megacitycode-renderer -> SDL3-static
    "node9" -> "node7"  // megacitycode-renderer -> megacitycode-types
    "node10" [ label = "megacitycode-window", shape = octagon, fillcolor="#7ec8a4", fontcolor="black" ];
    "node10" -> "node0"  // megacitycode-window -> SDL3-static
    "node10" -> "node7"  // megacitycode-window -> megacitycode-types
    "node9" -> "node10"  // megacitycode-renderer -> megacitycode-window
    "node11" [ label = "vk-bootstrap\n(vk-bootstrap::vk-bootstrap)", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
    "node9" -> "node11" [ style = dotted ] // megacitycode-renderer -> vk-bootstrap
    "node5" -> "node9" [ style = dotted ] // megacitycode -> megacitycode-renderer
    "node12" [ label = "megacitycode-tests", shape = egg, fillcolor="#f4e04d", fontcolor="black" ];
    "node12" -> "node6" [ style = dotted ] // megacitycode-tests -> megacitycode-font
    "node12" -> "node8" [ style = dotted ] // megacitycode-tests -> megacitycode-grid
    "node12" -> "node9" [ style = dotted ] // megacitycode-tests -> megacitycode-renderer
    "node13" [ label = "mpack_lib", shape = octagon, fillcolor="#e8e8e8", fontcolor="black" ];
}
