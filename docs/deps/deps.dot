digraph "megacitycode" {
node [
  fontsize = "12"
];
subgraph clusterLegend {
  label = "Legend";
  color = black;
  edge [ style = invis ];
  legendNode0 [ label = "Executable", shape = egg ];
  legendNode1 [ label = "Static Library", shape = octagon ];
  legendNode2 [ label = "Shared Library", shape = doubleoctagon ];
  legendNode3 [ label = "Module Library", shape = tripleoctagon ];
  legendNode4 [ label = "Interface Library", shape = pentagon ];
  legendNode5 [ label = "Object Library", shape = hexagon ];
  legendNode6 [ label = "Unknown Library", shape = septagon ];
  legendNode7 [ label = "Custom Target", shape = box ];
  legendNode0 -> legendNode1 [ style = solid ];
  legendNode0 -> legendNode2 [ style = solid ];
  legendNode0 -> legendNode3;
  legendNode1 -> legendNode4 [ label = "Interface", style = dashed ];
  legendNode2 -> legendNode5 [ label = "Private", style = dotted ];
  legendNode3 -> legendNode6 [ style = solid ];
  legendNode0 -> legendNode7;
}
    "node0" [ label = "SDL3-static\n(SDL3::SDL3)\n(SDL3::SDL3-static)", shape = octagon ];
    "node1" [ label = "SDL_uclibc", shape = octagon ];
    "node0" -> "node1"  // SDL3-static -> SDL_uclibc
    "node2" [ label = "SDL3_test\n(SDL3::SDL3_test)", shape = octagon ];
    "node3" [ label = "freetype", shape = octagon ];
    "node4" [ label = "harfbuzz", shape = octagon ];
    "node4" -> "node3"  // harfbuzz -> freetype
    "node5" [ label = "megacitycode", shape = egg ];
    "node6" [ label = "megacitycode-font", shape = octagon ];
    "node6" -> "node3"  // megacitycode-font -> freetype
    "node6" -> "node4"  // megacitycode-font -> harfbuzz
    "node7" [ label = "megacitycode-types", shape = octagon ];
    "node6" -> "node7"  // megacitycode-font -> megacitycode-types
    "node5" -> "node6" [ style = dotted ] // megacitycode -> megacitycode-font
    "node8" [ label = "megacitycode-grid", shape = octagon ];
    "node8" -> "node7"  // megacitycode-grid -> megacitycode-types
    "node5" -> "node8" [ style = dotted ] // megacitycode -> megacitycode-grid
    "node9" [ label = "megacitycode-renderer", shape = octagon ];
    "node9" -> "node0"  // megacitycode-renderer -> SDL3-static
    "node9" -> "node7"  // megacitycode-renderer -> megacitycode-types
    "node10" [ label = "megacitycode-window", shape = octagon ];
    "node10" -> "node0"  // megacitycode-window -> SDL3-static
    "node10" -> "node7"  // megacitycode-window -> megacitycode-types
    "node9" -> "node10"  // megacitycode-renderer -> megacitycode-window
    "node11" [ label = "vk-bootstrap\n(vk-bootstrap::vk-bootstrap)", shape = octagon ];
    "node9" -> "node11" [ style = dotted ] // megacitycode-renderer -> vk-bootstrap
    "node5" -> "node9" [ style = dotted ] // megacitycode -> megacitycode-renderer
    "node12" [ label = "megacitycode-tests", shape = egg ];
    "node12" -> "node6" [ style = dotted ] // megacitycode-tests -> megacitycode-font
    "node12" -> "node8" [ style = dotted ] // megacitycode-tests -> megacitycode-grid
    "node12" -> "node9" [ style = dotted ] // megacitycode-tests -> megacitycode-renderer
    "node13" [ label = "mpack_lib", shape = octagon ];
}
