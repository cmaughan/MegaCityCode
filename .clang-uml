# .clang-uml
# Configuration for clang-uml (https://clang-uml.github.io/)
# Generates a class diagram from C++ source using compile_commands.json.
#
# Usage:
#   clang-uml                              # generate all diagrams
#   python scripts/gen_uml.py              # generate + render to PNG/SVG
#   python scripts/gen_uml.py --diagram spectre_classes
#
# Diagrams are written to docs/uml/ as PlantUML (.puml) files.
# Render them with PlantUML or via scripts/gen_uml.py (which calls plantuml).

compilation_database_dir: ./build-tools
output_directory: ./docs/uml

diagrams:

  # ── Class diagram ────────────────────────────────────────────────────────
  # Shows all classes, interfaces, and structs in the spectre namespace with
  # their inheritance and composition relationships.
  spectre_classes:
    type: class
    title: "Spectre — Class Diagram"
    using_namespace: spectre
    glob:
      - libs/spectre-types/src/*.cpp
      - libs/spectre-window/src/*.cpp
      - libs/spectre-renderer/src/*.cpp
      - libs/spectre-renderer/src/vulkan/*.cpp
      - libs/spectre-font/src/font_manager.cpp
      - libs/spectre-font/src/glyph_cache.cpp
      # text_service.cpp excluded: clang-uml 0.6.2 on Windows hits STATUS_STACK_OVERFLOW,
      # but TextService still appears in the diagram through included headers.
      # grid.cpp excluded: triggers a clang-uml 0.6.2 crash (STATUS_ILLEGAL_INSTRUCTION)
      - libs/spectre-nvim/src/nvim_process.cpp
      - libs/spectre-nvim/src/rpc.cpp
      - libs/spectre-nvim/src/input.cpp
      - libs/spectre-nvim/src/mpack_codec.cpp
      # ui_events.cpp excluded: triggers a clang-uml 0.6.2 crash (STATUS_ILLEGAL_INSTRUCTION)
      - app/app.cpp
    include:
      namespaces:
        - spectre
    exclude:
      namespaces:
        - std
        - mpack
        - boost
        - freetype
        - harfbuzz
      elements:
        - spectre::MpackValue::ArrayStorage
        - spectre::MpackValue::MapStorage
        - spectre::MpackValue::Storage
    generate_method_arguments: none
    generate_packages: false

  # Package diagram omitted: all code lives in one 'spectre' namespace so
  # there are no sub-namespaces to group. Library-level dependencies are
  # better visualised by the CMake graphviz graph (docs/deps/deps.svg).
