# .clang-uml
# Configuration for clang-uml (https://clang-uml.github.io/)
# Generates a class diagram from C++ source using compile_commands.json.
#
# Usage:
#   clang-uml                              # generate all diagrams
#   python scripts/gen_uml.py              # generate + render to PNG/SVG
#   python scripts/gen_uml.py --diagram megacitycode_classes
#
# Diagrams are written to docs/uml/ as PlantUML (.puml) files.
# Render them with PlantUML or via scripts/gen_uml.py (which calls plantuml).

compilation_database_dir: ./build-tools
output_directory: ./docs/uml

diagrams:

  # ── Class diagram ────────────────────────────────────────────────────────
  # Shows all classes, interfaces, and structs in the megacitycode namespace with
  # their inheritance and composition relationships.
  megacitycode_classes:
    type: class
    title: "MegaCityCode — Class Diagram"
    using_namespace: megacitycode
    glob:
      - libs/megacitycode-types/src/*.cpp
      - libs/megacitycode-window/src/*.cpp
      - libs/megacitycode-renderer/src/*.cpp
      - libs/megacitycode-renderer/src/vulkan/*.cpp
      - libs/megacitycode-font/src/font_manager.cpp
      - libs/megacitycode-font/src/glyph_cache.cpp
      # text_service.cpp excluded: clang-uml 0.6.2 on Windows hits STATUS_STACK_OVERFLOW,
      # but TextService still appears in the diagram through included headers.
      - libs/megacitycode-grid/src/grid.cpp
      - app/app.cpp
    include:
      namespaces:
        - megacitycode
    exclude:
      namespaces:
        - std
        - mpack
        - boost
        - freetype
        - harfbuzz
      elements:
        - megacitycode::MpackValue::ArrayStorage
        - megacitycode::MpackValue::MapStorage
        - megacitycode::MpackValue::Storage
    generate_method_arguments: none
    generate_packages: false

  # Package diagram omitted: all code lives in one 'megacitycode' namespace so
  # there are no sub-namespaces to group. Library-level dependencies are
  # better visualised by the CMake graphviz graph (docs/deps/deps.svg).
